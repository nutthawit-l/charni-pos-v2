    "lint": "eslint .",
    "preview": "vite preview",
    "deploy": "pnpm build && wrangler pages deploy dist/client",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b && tsc -p functions/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@react-oauth/google": "^0.13.5",
    "@react-router/node": "^8.1.0",
    "clsx": "^2.1.1",
    "isbot": "^5",
